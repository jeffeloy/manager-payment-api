# Variáveis para Render (Dashboard → Environment).
# Não commitar valores reais.

APP_NAME="Manager Payment API"
APP_ENV=production
APP_DEBUG=false
APP_KEY=                    # Render pode gerar automaticamente (generateValue)
APP_URL=https://manager-payment-api.onrender.com

DB_CONNECTION=pgsql
DB_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=database

LOG_LEVEL=warning

VITE_APP_NAME="${APP_NAME}"
EXCHANGE_RATE_API_URL=https://api.exchangerate-api.com/v4
EXCHANGE_RATE_SOURCE=https://api.exchangerate-api.com

# Opcional — persistir chaves OAuth entre redeploys:
# PASSPORT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# PASSPORT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
